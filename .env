# Frappe Fleet Management System - Environment Configuration
# Based on official frappe_docker: https://github.com/frappe/frappe_docker
# ============================================================

# Server Configuration
SERVER_IP=187.77.2.74
FRAPPE_PORT=80
PHPMYADMIN_PORT=8080

# Frappe/ERPNext Version
ERPNEXT_VERSION=v16

# MariaDB Configuration
MARIADB_ROOT_PASSWORD=Agro123!
MARIADB_DATABASE=erpnext
MARIADB_USER=erpnext_user
MARIADB_PASSWORD=Agro123!
DB_PASSWORD=Agro123!

# Site Configuration
FRAPPE_SITE_NAME_HEADER=${SITE_NAME}
SITE_NAME=fleetmanagement

# Nginx Configuration
UPSTREAM_REAL_IP_ADDRESS=127.0.0.1
UPSTREAM_REAL_IP_HEADER=X-Forwarded-For
PROXY_READ_TIMEOUT=300
CLIENT_MAX_BODY_SIZE=50m

# Docker Configuration
RESTART_POLICY=unless-stopped
PULL_POLICY=always

# Custom Image (optional - use default frappe/erpnext)
# CUSTOM_IMAGE=frappe/erpnext
# CUSTOM_TAG=v16

# Timezone
TZ=America/New_York
