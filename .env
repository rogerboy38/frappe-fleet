# Frappe Fleet Management System - Environment Configuration
# ============================================================

# Server Configuration
SERVER_IP=187.77.2.74
FRAPPE_PORT=80
PHPMYADMIN_PORT=8080

# MariaDB Configuration
MARIADB_ROOT_PASSWORD=ChangeMeRootPassword2024!
MARIADB_DATABASE=erpnext
MARIADB_USER=erpnext_user
MARIADB_PASSWORD=ChangeMeUserPassword2024!

# Frappe Configuration
FRAPPE_VERSION=v15
FRAPPE_SITE=erp.fleetsysmayal.cloud
ADMIN_PASSWORD=AdminChangeMe2024!
SITE_NAME=fleetmanagement

# Encryption Keys (generate unique keys for production)
SECRET_KEY=ChangeMeSecretKeyChangeMeSecretKey2024
ENCRYPTION_KEY=ChangeMeEncryptionKeyChangeMe2024

# Redis Configuration (internal - managed by Docker)
# No external Redis configuration needed

# Timezone
TZ=America/New_York

# Python Configuration
PYTHONUNBUFFERED=1

# Node Configuration
NODE_ENV=production

# Frappe Performance Settings
WORKER_CLASS=gthread
WORKER_PROCESSES=auto
TIMEOUT=120
